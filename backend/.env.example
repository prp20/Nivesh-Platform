# Stock Nivesh Platform — Environment Configuration Example
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql+asyncpg://nivesh_admin:nivesh_password_123@localhost:5432/nivesh_db

# ============================================================================
# API SERVER
# ============================================================================
PROJECT_NAME=Nivesh API
API_V1_STR=/api/v1

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# Enable JWT-based authentication (default: true — all routes require a valid Bearer token)
# Set to false only for local development or test environments
ENABLE_AUTH=true

# Secret key for JWT signing (REQUIRED if ENABLE_AUTH=true)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# NEVER use the same key in dev and production!
SECRET_KEY=dev-secret-key-do-not-use-in-production

# JWT token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin token for accessing sensitive pipeline endpoints in dev mode
# Only required when ENABLE_AUTH=false (dev) and you want to protect pipeline endpoints
ADMIN_TOKEN=your-dev-admin-token-here

# ============================================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================================
# Comma-separated list of allowed origins for frontend requests
# Format: https://domain.com,https://another.com

# LOCAL DEVELOPMENT
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# STAGING
# ALLOWED_ORIGINS=https://app-staging.nivesh.in,https://admin-staging.nivesh.in

# PRODUCTION
# ALLOWED_ORIGINS=https://app.nivesh.in,https://admin.nivesh.in

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================
# 1. For production, use strong cryptographic values:
#    - SECRET_KEY: 32+ character random string
#    - DATABASE_URL: Use strong password, managed secret
#    - ADMIN_TOKEN: Complex token or disabled (use JWT roles instead)

# 2. Set ENABLE_AUTH=true in production with a secure SECRET_KEY

# 3. Configure ALLOWED_ORIGINS for your production domain(s)

# 4. Store this file in a secure location (AWS Secrets Manager, HashiCorp Vault, etc.)
#    Do NOT store in git, do NOT share credentials

# 5. Use environment-specific .env files in deployment pipeline:
#    - .env.development (local)
#    - .env.staging
#    - .env.production (vault/secrets manager)
