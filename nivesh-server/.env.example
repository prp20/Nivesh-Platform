# ─────────────────────────────────────────────────────────────
# nivesh-server environment variables
# Copy this file to .env and fill in your Supabase credentials.
# NEVER commit the .env file to git.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────

# Runtime connection — Supavisor POOLER (port 6543, IPv4, transaction mode)
# Used by FastAPI routes at runtime.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Migration connection — DIRECT URL (port 5432, session mode)
# Used ONLY by: alembic upgrade head
# Do NOT use this at runtime — it uses IPv6 which fails on Render free tier.
ALEMBIC_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Auth ──────────────────────────────────────────────────────

# JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-256-bit-random-string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ───────────────────────────────────────────────────────

ENVIRONMENT=development
APP_VERSION=0.1.0

# Set to true to enforce JWT on write endpoints
ENABLE_AUTH=false

# Required for admin-gated scripts when ENABLE_AUTH=true
ADMIN_PASSWORD=replace-with-secure-password
